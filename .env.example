# ===========================================
# UGC Influencer Outreach System - Environment
# ===========================================

# Database
DATABASE_URL=postgresql+asyncpg://ugc:ugc_password@localhost:5432/ugc_db
DATABASE_URL_SYNC=postgresql://ugc:ugc_password@localhost:5432/ugc_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-to-a-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
FRONTEND_URL=http://localhost:4317
BASE_URL=http://localhost:8917
NEXT_PUBLIC_API_URL=http://localhost:8917

# AI Providers (set the one you want to use)
AI_PROVIDER=claude
CLAUDE_API_KEY=
OPENAI_API_KEY=

# Email - Amazon SES
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
SES_REGION=us-east-1

# Email - SendGrid
SENDGRID_API_KEY=

# Email - SMTP (generic)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# WotoHub Discovery API
WOTO_API_KEY=
WOTO_API_BASE_URL=https://api.wotohub.com/api-gateway
WOTO_REQUEST_TIMEOUT_SECONDS=30
WOTO_PAGE_SIZE=50
WOTO_DEFAULT_SYNC_LIMIT=50

# App Settings
APP_NAME=UGC Influencer Outreach
APP_ENV=development
LOG_LEVEL=INFO
